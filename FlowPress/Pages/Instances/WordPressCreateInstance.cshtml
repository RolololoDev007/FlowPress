@page "/create"
@model WordPressCreateInstance

@{
    ViewData["Title"] = "Create Instance";
    Layout = "_Layout";
}

@section Styles {
    <link href="~/css/Instances/create-instance.css" rel="stylesheet"/>
}

<main class="create-container">
    <div class="create-content">
        <div class="create-wrapper">
            <div class="breadcrumb">
                <a class="breadcrumb-link" href="/instances">Instances</a>
                <span class="breadcrumb-link">/</span>
                <span class="breadcrumb-current">Launch New Site</span>
            </div>

            <div class="page-header">
                <h1 class="page-title">Launch a New WordPress Instance</h1>
                <p class="page-subtitle">Fill in the details below to get your new site up and running.</p>
            </div>

            <div class="form-card">
                <form method="post" class="form-container">
                    <label class="flex flex-col">
                        <p class="form-label">Site Name</p>
                        <input asp-for="InstancesModel.SiteName"
                               class="form-input"
                               placeholder="My Awesome Blog"
                               type="text"/>
                        <span asp-validation-for="InstancesModel.SiteName" class="validation-error"></span>
                    </label>

                    <label class="flex flex-col">
                        <p class="form-label">Site Address</p>
                        <div class="input-group">
                            <input asp-for="InstancesModel.SiteAddress"
                                   class="input-group-input"
                                   placeholder="Enter your site address"/>
                            <div class="input-group-suffix">
                                <span style="font-size: 16px;">flowpress.site</span>
                            </div>
                        </div>
                        <span asp-validation-for="InstancesModel.SiteAddress" class="validation-error"></span>
                        <p class="success-message">
                            <span class="material-symbols-outlined" style="font-size: 1rem;">check_circle</span>
                            Subdomain is available!
                        </p>
                    </label>
                    <div style="padding-top: 1rem;">
                        <button type="submit" class="btn-submit">Launch Site</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</main>