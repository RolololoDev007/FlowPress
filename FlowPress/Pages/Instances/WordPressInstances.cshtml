@page "/instances"
@model FlowPress.Pages.Instances.WordPressInstances

@{
    ViewData["Title"] = "Instances";
    Layout = "_Layout";
}

<div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
    <div class="layout-container flex h-full grow flex-col">
        <div class="px-4 sm:px-6 md:px-10 lg:px-20 xl:px-40 flex flex-1 justify-center py-5">
            <div class="layout-content-container flex flex-col w-full max-w-7xl flex-1">
                <main class="mt-8">
                    <!-- Page Heading -->
                    <div class="flex flex-wrap justify-between gap-3 p-4">
                        <p class="text-black dark:text-white text-4xl font-black leading-tight tracking-[-0.033em] min-w-72">
                            WordPress Instances
                        </p>
                        <a class="flex min-w-[84px] max-w-[480px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 bg-blue-500 px-4 bg-primary text-white text-sm font-bold leading-normal tracking-[0.015em] hover:bg-primary/90 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-100"
                            href="/create">
                            <span class="truncate">+ Deploy New Instance</span>
                        </a>
                    </div>

                    <!-- Toolbar: Search and Filter -->
                    <div class="flex flex-col sm:flex-row justify-between gap-4 px-4 py-3">
                        <div class="relative flex-grow">
                            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                                <span class="material-symbols-outlined text-gray-400 dark:text-gray-500">search</span>
                            </div>
                            <input class="w-full sm:w-80 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-black dark:text-white pl-10 pr-4 py-2 focus:ring-2 focus:ring-primary focus:border-primary"
                                placeholder="Search by name or subdomain..." type="text"/>
                        </div>
                        <div class="flex gap-2">
                            <button class="flex items-center gap-2 p-2 rounded-lg text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                                <span class="material-symbols-outlined text-base">filter_list</span>
                                <span class="text-sm">Filters</span>
                            </button>
                            <button class="flex items-center gap-2 p-2 rounded-lg text-gray-600 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                                <span class="material-symbols-outlined text-base">swap_vert</span>
                                <span class="text-sm">Sort</span>
                            </button>
                        </div>
                    </div>

                    <!-- Instances Table -->
                    <div class="px-4 py-3">
                        <div class="flex overflow-hidden rounded-lg border border-gray-200 dark:border-[#3b4754] bg-white dark:bg-[#111418]">
                            <table class="w-full">
                                <thead>
                                <tr class="bg-gray-50 dark:bg-[#1c2127]">
                                    <th class="px-6 py-4 text-left text-gray-600 dark:text-white text-xs font-medium uppercase tracking-wider">
                                        Site Name
                                    </th>
                                    <th class="px-6 py-4 text-left text-gray-600 dark:text-white text-xs font-medium uppercase tracking-wider">
                                        Subdomain
                                    </th>
                                    <th class="px-6 py-4 text-left text-gray-600 dark:text-white text-xs font-medium uppercase tracking-wider">
                                        Status
                                    </th>
                                    <th class="px-6 py-4 text-left text-gray-600 dark:text-white text-xs font-medium uppercase tracking-wider">
                                        Actions
                                    </th>
                                </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200 dark:divide-[#3b4754]">
                                <!-- Ejemplo de fila estática -->
                                <tbody class="divide-y divide-gray-200 dark:divide-[#3b4754]">
                                @foreach (var instance in Model.Instances)
                                {
                                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-black dark:text-white">@instance.SiteName</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-[#9dabb9]">@instance.SiteAddress</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm">
                                            @* ROLO Pensar como poner el estado (Mirar API de Kuma)  *@
                                            @* <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold @(instance.Status == "Live" ? "bg-green-100 dark:bg-green-900/50 text-green-800 dark:text-green-300" : "")"> *@
                                            @*     <span class="h-2 w-2 rounded-full @(instance.Status == "Live" ? "bg-green-500" : "")"></span> *@
                                            @*     @instance.Status *@
                                            @* </span> *@
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                            <div class="flex items-center gap-2">
                                                <a asp-page="/Instances/WordPressInstanceInfo" 
                                                   asp-route-id="@instance.Id"
                                                   class="p-2 rounded-full text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 hover:text-primary dark:hover:text-primary transition-colors">
                                                    <span class="material-symbols-outlined">settings</span>
                                                </a>
                                                <button class="p-2 rounded-full text-gray-500 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700 hover:text-primary dark:hover:text-primary transition-colors">
                                                    <span class="material-symbols-outlined">backup</span>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <div class="flex items-center justify-center p-4">
                        <nav aria-label="Pagination" class="flex items-center gap-1">
                            <a class="flex size-10 items-center justify-center rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">
                                <span class="material-symbols-outlined">chevron_left</span>
                            </a>
                            <a class="text-sm font-bold flex size-10 items-center justify-center text-white rounded-lg bg-primary"
                               href="#">1</a>
                            <a class="text-sm font-normal flex size-10 items-center justify-center text-gray-700 dark:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">2</a>
                            <a class="text-sm font-normal flex size-10 items-center justify-center text-gray-700 dark:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">3</a>
                            <span class="text-sm font-normal flex size-10 items-center justify-center text-gray-500 dark:text-gray-400">...</span>
                            <a class="text-sm font-normal flex size-10 items-center justify-center text-gray-700 dark:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">8</a>
                            <a class="text-sm font-normal flex size-10 items-center justify-center text-gray-700 dark:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">9</a>
                            <a class="text-sm font-normal flex size-10 items-center justify-center text-gray-700 dark:text-white rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">10</a>
                            <a class="flex size-10 items-center justify-center rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                               href="#">
                                <span class="material-symbols-outlined">chevron_right</span>
                            </a>
                        </nav>
                    </div>
                </main>
            </div>
        </div>
    </div>
</div>
