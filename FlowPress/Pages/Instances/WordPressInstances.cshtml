@page "/instances"
@model FlowPress.Pages.Instances.WordPressInstances

@{
    ViewData["Title"] = "Instancias";
    Layout = "_Layout";
}

@section Styles{
    <link rel="stylesheet" href="~/css/Instances/instances.css" asp-append-version="true"/>
}

<div class="page-wrapper">
    <div class="layout-container">
        <main class="layout-content">
            <header class="page-header">
                <h1 class="page-title">WordPress Instances</h1>
                <a href="/create" class="create-button">+ Crear nueva instancia</a>
            </header>
            <section class="toolbar">
                <div class="search-wrapper">
                    <span class="material-symbols-outlined search-icon">search</span>
                    <input class="search-input" placeholder="Buscar por nombre o dominio..."/>
                </div>
                <div class="filter-buttons">
                    <button class="toolbar-button">
                        <span class="material-symbols-outlined">filter_list</span>
                        Filtrar
                    </button>
                    <button class="toolbar-button">
                        <span class="material-symbols-outlined">swap_vert</span>
                        Ordenar
                    </button>
                </div>
            </section>
            <section class="table-container">
                <table class="instances-table">
                    <thead>
                    <tr>
                        <th>Nombre del sitio</th>
                        <th>Dominio</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var instance in Model.Instances ?? Enumerable.Empty<FlowPress.Models.InstancesModel>())
                    {
                        var statusDisplay = instance.DockerStatus switch
                        {
                            "running" => "Encendido",
                            "stopped" => "Apagado",
                            "restarted" => "Reiniciando",
                            "pending" => "Pendiente",
                            "error" => "Error",
                            _ => "Desconocido"
                        };

                        <tr>
                            <td>@instance.SiteName</td>
                            <td><a href="https://@instance.SiteAddress" target="_blank">@instance.SiteAddress</a></td>
                            <td>
                                <span class="status-badge status-@(instance.DockerStatus ?? "unknown")">
                                        <span class="status-dot"></span>
                                    @statusDisplay
                                    </span>
                            </td>
                            <td>
                                <div class="actions">
                                    <a class="action-button" asp-page="/Instances/WordPressInstanceInfo"
                                       asp-route-id="@instance.Id">
                                        <span class="material-symbols-outlined">settings</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </section>
        </main>
    </div>
</div>
