@page "/instanceinfo/{id:guid}"
@model FlowPress.Pages.Instances.WordPressInstanceInfo

@{
    Layout = "_Layout";
    ViewData["Title"] = "Instance Info";

    var statusClasses = Model.Instance?.DockerStatus switch
    {
        "running" => ("bg-green-100 dark:bg-green-900/40", "bg-green-500", "text-green-800 dark:text-green-400", "Running"),
        "stopped" => ("bg-red-100 dark:bg-red-900/40", "bg-red-500", "text-red-800 dark:text-red-400", "Stopped"),
        "restarted" => ("bg-orange-100 dark:bg-yellow-900/40", "bg-orange-500", "text-orange-800 dark:text-orange-400", "Restarting"),
        "pending" => ("bg-yellow-100 dark:bg-yellow-900/40", "bg-yellow-500", "text-yellow-800 dark:text-yellow-400", "Pending"),
        _ => ("bg-gray-100 dark:bg-gray-900/40", "bg-gray-500", "text-gray-800 dark:text-gray-400", "Unknown")
    };
}

@section Styles{
    <link href="~/css/Instances/instances-info.css" rel="stylesheet"/>
}

<main class="instance-container">
    <div class="instance-content">
        <header class="instance-header">
            <div class="breadcrumb">
                <a class="breadcrumb-link" href="/instances">Instances</a>
                <span class="breadcrumb-link">/</span>
                <span class="breadcrumb-current">@Model.Instance?.SiteName</span>
            </div>
            <div class="header-content">
                <div class="header-title-group">
                    <h1 class="page-title">@Model.Instance?.SiteName</h1>
                </div>
                <div class="status-badge @statusClasses.Item1">
                    <span class="status-dot @statusClasses.Item2"></span>
                    <p class="status-text @statusClasses.Item3">@statusClasses.Item4</p>
                </div>
            </div>
        </header>

        <div class="grid-layout">
            <!-- Left Column -->
            <div class="flex flex-col gap-8">
                <div class="card">
                    <h2 class="card-title card-header">Instance Details</h2>
                    <div class="card-body details-grid">
                        <div class="detail-item">
                            <p class="detail-label">Site URL</p>
                            <a class="detail-link" href="https://@($"{Model.Instance?.SiteAddress}")">
                                @($"{Model.Instance?.SiteAddress}")
                            </a>
                        </div>
                        <div class="detail-item">
                            <p class="detail-label">WordPress Version</p>
                            <p class="detail-value">6.1.1</p>
                        </div>
                    </div>
                </div>

                <section class="card">
                    <header class="card-header">
                        <h2 class="card-title">Monitoring</h2>
                    </header>
                    <div class="card-body" style="display: flex; flex-direction: column; gap: 1rem;">
                        <div class="monitoring-item">
                            <span class="monitoring-label">Current Status</span>
                            <span class="monitoring-value">Up</span>
                        </div>
                        <div>
                            <div class="monitoring-item progress-bar-wrapper">
                                <span class="monitoring-label">Uptime (30 days)</span>
                                <span class="detail-value">99.98%</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" style="width: 99.98%"></div>
                            </div>
                        </div>
                        <a class="detail-link" href="#" style="display: flex; align-items: center; gap: 0.375rem;">
                            <span>View Full Status Page</span>
                            <span class="material-symbols-outlined" style="font-size: 0.875rem;">arrow_forward</span>
                        </a>
                    </div>
                </section>
            </div>

            <!-- Right Column -->
            <div class="flex flex-col gap-8">
                <!-- Primary Actions -->
                <div class="card">
                    <h2 class="card-title card-header">Primary Actions</h2>
                    <div class="card-body action-buttons">
                        <form method="post">
                            <button asp-page-handler="Start" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-start"
                                    disabled="@(Model.Instance.DockerStatus == "running" || Model.Instance.DockerStatus == "pending" || Model.Instance.DockerStatus == "restarted"))">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">play_arrow</span>
                                <span>Start</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Stop" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-stop"
                                    disabled="@(Model.Instance.DockerStatus == "stopped" || Model.Instance.DockerStatus == "pending" || Model.Instance.DockerStatus == "restarted")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">stop</span>
                                <span>Stop</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Restart" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-restart"
                                    disabled="@(Model.Instance.DockerStatus == "stopped" || Model.Instance.DockerStatus == "pending" || Model.Instance.DockerStatus == "restarted")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">refresh</span>
                                <span>Restart</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Danger Zone -->
                <div class="danger-zone">
                    <h3 class="danger-title">Danger Zone</h3>
                    <p class="danger-description">These actions are permanent and cannot be undone.</p>

                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('¿Estás seguro que quieres eliminar esta instancia? Esta acción no se puede deshacer.');"
                          class="danger-action">
                        <input type="hidden" name="id" value="@Model.Instance?.Id"/>
                        <div>
                            <p class="danger-action-text">Delete this instance</p>
                            <p class="danger-action-description">Once deleted, it's gone forever.</p>
                        </div>
                        <button type="submit" class="btn-danger">Delete Instance</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>