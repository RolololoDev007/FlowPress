@page "/instanceinfo/{id:guid}"
@model FlowPress.Pages.Instances.WordPressInstanceInfo

@{
    Layout = "_Layout";
    ViewData["Title"] = "Instance Info";

    var statusClasses = Model.Instance?.DockerStatus switch
    {
        "running" => ("bg-green-100 dark:bg-green-900/40", "bg-green-500", "text-green-800 dark:text-green-400", "Running"),
        "stopped" => ("bg-red-100 dark:bg-red-900/40", "bg-red-500", "text-red-800 dark:text-red-400", "Stopped"),
        "restarted" => ("bg-yellow-100 dark:bg-yellow-900/40", "bg-yellow-500", "text-yellow-800 dark:text-yellow-400", "Restarting"),
        _ => ("bg-gray-100 dark:bg-gray-900/40", "bg-gray-500", "text-gray-800 dark:text-gray-400", "Unknown")
    };
}

<style>
    .instance-container {
        flex: 1;
        padding: 1.5rem;
    }

    .instance-content {
        margin: 0 auto;
        max-width: 80rem;
    }

    .instance-header {
        margin-bottom: 2rem;
    }

    .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .breadcrumb-link {
        color: #6b7280;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .breadcrumb-link:hover {
        color: #3b82f6;
    }

    .breadcrumb-current {
        color: #111827;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .header-content {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .header-title-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-title {
        color: #111827;
        font-size: 1.875rem;
        font-weight: 900;
        line-height: 1.2;
        letter-spacing: -0.033em;
    }

    .status-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
    }

    .status-dot {
        height: 0.5rem;
        width: 0.5rem;
        border-radius: 9999px;
    }

    .status-text {
        font-size: 0.875rem;
        font-weight: 500;
    }

    .grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    .card {
        background-color: #ffffff;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    }

    .card-header {
        padding: 1rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .card-title {
        color: #111827;
        font-size: 1.125rem;
        font-weight: 700;
    }

    .card-body {
        padding: 1rem;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding-right: 0.5rem;
    }

    .detail-label {
        color: #6b7280;
        font-size: 0.875rem;
    }

    .detail-value {
        color: #111827;
        font-size: 0.875rem;
    }

    .detail-link {
        color: #3b82f6;
        font-size: 0.875rem;
    }

    .detail-link:hover {
        text-decoration: underline;
    }

    .monitoring-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .monitoring-label {
        color: #6b7280;
        font-size: 0.875rem;
    }

    .monitoring-value {
        color: #10b981;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .progress-bar-wrapper {
        margin-top: 0.25rem;
    }

    .progress-bar-bg {
        width: 100%;
        height: 0.5rem;
        background-color: #e5e7eb;
        border-radius: 9999px;
    }

    .progress-bar-fill {
        height: 0.5rem;
        background-color: #10b981;
        border-radius: 9999px;
    }

    .action-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .btn-action {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        height: 2.5rem;
        padding: 0 1rem;
        border-radius: 0.5rem;
        font-size: 0.875rem;
        font-weight: 700;
        transition: background-color 0.2s;
    }

    .btn-action:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-start {
        background-color: rgb(22 163 74 / 0.1);
        color: #16a34a;
    }

    .btn-start:hover:not(:disabled) {
        background-color: rgb(22 163 74 / 0.2);
    }

    .btn-stop {
        background-color: rgb(220 38 38 / 0.1);
        color: #dc2626;
    }

    .btn-stop:hover:not(:disabled) {
        background-color: rgb(220 38 38 / 0.2);
    }

    .btn-restart {
        background-color: rgb(234 179 8 / 0.1);
        color: #ca8a04;
    }

    .btn-restart:hover:not(:disabled) {
        background-color: rgb(234 179 8 / 0.2);
    }

    .danger-zone {
        border: 1px solid rgb(239 68 68 / 0.3);
        border-radius: 0.75rem;
        padding: 1rem;
    }

    .danger-title {
        color: #b91c1c;
        font-size: 1.125rem;
        font-weight: 700;
    }

    .danger-description {
        color: rgb(220 38 38 / 0.8);
        font-size: 0.875rem;
        margin-top: 0.25rem;
    }

    .danger-action {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 1rem;
    }

    .danger-action-text {
        color: #111827;
        font-weight: 500;
    }

    .danger-action-description {
        color: #6b7280;
        font-size: 0.875rem;
    }

    .btn-danger {
        height: 2.5rem;
        padding: 0 1rem;
        border-radius: 0.5rem;
        background-color: #dc2626;
        color: white;
        font-size: 0.875rem;
        font-weight: 700;
    }

    .btn-danger:hover {
        background-color: #b91c1c;
    }

    @@media (min-width: 640px) {
        .details-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 1024px) {
        .instance-container {
            padding: 2.5rem;
        }

        .page-title {
            font-size: 2.25rem;
        }

        .grid-layout {
            grid-template-columns: 1fr 2fr;
        }

        .details-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (prefers-color-scheme: dark) {
        .breadcrumb-link {
            color: #9dabb9;
        }

        .breadcrumb-current {
            color: white;
        }

        .page-title {
            color: white;
        }

        .card {
            background-color: #1C2834;
        }

        .card-header {
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        .card-title {
            color: white;
        }

        .detail-label {
            color: #9dabb9;
        }

        .detail-value {
            color: white;
        }

        .monitoring-label {
            color: #94a3b8;
        }

        .progress-bar-bg {
            background-color: #475569;
        }

        .danger-zone {
            border-color: rgb(239 68 68 / 0.5);
        }

        .danger-title {
            color: #f87171;
        }

        .danger-description {
            color: rgb(248 113 113 / 0.8);
        }

        .danger-action-text {
            color: white;
        }

        .danger-action-description {
            color: #9ca3af;
        }
    }
</style>

<main class="instance-container">
    <div class="instance-content">
        <header class="instance-header">
            <div class="breadcrumb">
                <a class="breadcrumb-link" href="/instances">Instances</a>
                <span class="breadcrumb-link">/</span>
                <span class="breadcrumb-current">@Model.Instance?.SiteName</span>
            </div>
            <div class="header-content">
                <div class="header-title-group">
                    <h1 class="page-title">@Model.Instance?.SiteName</h1>
                </div>
                <div class="status-badge @statusClasses.Item1">
                    <span class="status-dot @statusClasses.Item2"></span>
                    <p class="status-text @statusClasses.Item3">@statusClasses.Item4</p>
                </div>
            </div>
        </header>

        <div class="grid-layout">
            <!-- Left Column -->
            <div class="flex flex-col gap-8">
                <div class="card">
                    <h2 class="card-title card-header">Instance Details</h2>
                    <div class="card-body details-grid">
                        <div class="detail-item">
                            <p class="detail-label">Site URL</p>
                            <a class="detail-link" href="https://@($"{Model.Instance?.SiteAddress}")">
                                @($"{Model.Instance?.SiteAddress}")
                            </a>
                        </div>
                        <div class="detail-item">
                            <p class="detail-label">WordPress Version</p>
                            <p class="detail-value">6.1.1</p>
                        </div>
                    </div>
                </div>

                <section class="card">
                    <header class="card-header">
                        <h2 class="card-title">Monitoring</h2>
                    </header>
                    <div class="card-body" style="display: flex; flex-direction: column; gap: 1rem;">
                        <div class="monitoring-item">
                            <span class="monitoring-label">Current Status</span>
                            <span class="monitoring-value">Up</span>
                        </div>
                        <div>
                            <div class="monitoring-item progress-bar-wrapper">
                                <span class="monitoring-label">Uptime (30 days)</span>
                                <span class="detail-value">99.98%</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill" style="width: 99.98%"></div>
                            </div>
                        </div>
                        <a class="detail-link" href="#" style="display: flex; align-items: center; gap: 0.375rem;">
                            <span>View Full Status Page</span>
                            <span class="material-symbols-outlined" style="font-size: 0.875rem;">arrow_forward</span>
                        </a>
                    </div>
                </section>
            </div>

            <!-- Right Column -->
            <div class="flex flex-col gap-8">
                <!-- Primary Actions -->
                <div class="card">
                    <h2 class="card-title card-header">Primary Actions</h2>
                    <div class="card-body action-buttons">
                        <form method="post">
                            <button asp-page-handler="Start" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-start"
                                    disabled="@(Model.Instance.DockerStatus == "running")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">play_arrow</span>
                                <span>Start</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Stop" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-stop"
                                    disabled="@(Model.Instance.DockerStatus == "stopped")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">stop</span>
                                <span>Stop</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Restart" asp-route-id="@Model.Instance.Id"
                                    class="btn-action btn-restart"
                                    disabled="@(Model.Instance.DockerStatus == "restarted" || Model.Instance.DockerStatus == "stopped")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">refresh</span>
                                <span>Restart</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Danger Zone -->
                <div class="danger-zone">
                    <h3 class="danger-title">Danger Zone</h3>
                    <p class="danger-description">These actions are permanent and cannot be undone.</p>

                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('¿Estás seguro que quieres eliminar esta instancia? Esta acción no se puede deshacer.');"
                          class="danger-action">
                        <input type="hidden" name="id" value="@Model.Instance?.Id"/>
                        <div>
                            <p class="danger-action-text">Delete this instance</p>
                            <p class="danger-action-description">Once deleted, it's gone forever.</p>
                        </div>
                        <button type="submit" class="btn-danger">Delete Instance</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>