@page "/instanceinfo/{id:guid}"
@model FlowPress.Pages.Instances.WordPressInstanceInfo

@{
    Layout = "_Layout";
    ViewData["Title"] = "Información de la Instancia";
    var instanceId = Model.Instance?.Id;

    var statusClasses = Model.Instance?.DockerStatus switch
    {
        "running" => ("bg-green-100 dark:bg-green-900/40", "bg-green-500", "text-green-800 dark:text-green-400", "Encendido"),
        "stopped" => ("bg-red-100 dark:bg-red-900/40", "bg-red-500", "text-red-800 dark:text-red-400", "Apagado"),
        "restarted" => ("bg-orange-100 dark:bg-yellow-900/40", "bg-orange-500", "text-orange-800 dark:text-orange-400", "Reiniciando"),
        "pending" => ("bg-yellow-100 dark:bg-yellow-900/40", "bg-yellow-500", "text-yellow-800 dark:text-yellow-400", "Pendiente"),
        "error" => ("bg-red-100 dark:bg-red-900/40", "bg-red-500", "text-red-800 dark:text-red-400", "Error"),
        _ => ("bg-gray-100 dark:bg-gray-900/40", "bg-gray-500", "text-gray-800 dark:text-gray-400", "Desconocido")
    };

    var monitoringClasses = Model.Monitoring?.IsHealthy == true
        ? ("monitoring-status-good", "monitoring-progress-good")
        : ("monitoring-status-bad", "monitoring-progress-bad");
}

@section Styles{
    <link href="~/css/Instances/instances-info.css" rel="stylesheet"/>
}

<main class="instance-container">
    <div class="instance-content">
        <header class="instance-header">
            <div class="breadcrumb">
                <a class="breadcrumb-link" href="/instances">Instancias</a>
                <span class="breadcrumb-link">/</span>
                <span class="breadcrumb-current">@Model.Instance?.SiteName</span>
            </div>
            <div class="header-content">
                <div class="header-title-group">
                    <h1 class="page-title">@Model.Instance?.SiteName</h1>
                </div>
                <div class="status-badge @statusClasses.Item1">
                    <span class="status-dot @statusClasses.Item2"></span>
                    <p class="status-text @statusClasses.Item3">@statusClasses.Item4</p>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="mb-6 rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-green-800">
                @Model.Message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-6 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800">
                @Model.ErrorMessage
            </div>
        }

        <div class="grid-layout">
            <!-- Left Column -->
            <div class="flex flex-col gap-8">
                <div class="card">
                    <h2 class="card-title card-header">Detalles de la instancia</h2>
                    <div class="card-body details-grid">
                        <div class="detail-item">
                            <p class="detail-label">Dirección del sitio</p>
                            <a class="detail-link" href="https://@($"{Model.Instance?.SiteAddress}")" target="_blank">
                                @($"{Model.Instance?.SiteAddress}")
                            </a>
                        </div>
                    </div>
                </div>

                <section class="card">
                    <header class="card-header">
                        <h2 class="card-title">Monitoreo</h2>
                    </header>
                    <div class="card-body monitoring-card-body">
                        <div class="monitoring-item">
                            <span class="monitoring-label">Estado actual</span>
                            <span class="monitoring-value @monitoringClasses.Item1">@Model.Monitoring?.StatusLabel</span>
                        </div>
                        <div>
                            <div class="monitoring-item progress-bar-wrapper">
                                <span class="monitoring-label">Salud actual</span>
                                <span class="detail-value">@Model.Monitoring?.HealthScore%</span>
                            </div>
                            <div class="progress-bar-bg">
                                <div class="progress-bar-fill @monitoringClasses.Item2" style="width: @(Model.Monitoring?.HealthScore ?? 0)%"></div>
                            </div>
                        </div>
                        <div class="monitoring-grid">
                            <div class="detail-item">
                                <p class="detail-label">Resumen</p>
                                <p class="detail-value">@Model.Monitoring?.Summary</p>
                            </div>
                            <div class="detail-item">
                                <p class="detail-label">Código HTTP</p>
                                <p class="detail-value">@(Model.Monitoring?.StatusCode?.ToString() ?? "Sin respuesta")</p>
                            </div>
                            <div class="detail-item">
                                <p class="detail-label">Tiempo de respuesta</p>
                                <p class="detail-value">@(Model.Monitoring?.ResponseTimeMs is long ms ? $"{ms} ms" : "No disponible")</p>
                            </div>
                            <div class="detail-item">
                                <p class="detail-label">Última comprobación</p>
                                <p class="detail-value">@Model.Monitoring?.CheckedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</p>
                            </div>
                            <div class="detail-item">
                                <p class="detail-label">URL comprobada</p>
                                @if (!string.IsNullOrWhiteSpace(Model.Monitoring?.CheckedUrl))
                                {
                                    <a class="detail-link" href="@Model.Monitoring.CheckedUrl" target="_blank">
                                        @Model.Monitoring.CheckedUrl
                                    </a>
                                }
                                else
                                {
                                    <p class="detail-value">No disponible</p>
                                }
                            </div>
                        </div>
                        <div class="monitoring-links">
                            <a class="detail-link" asp-page="/Instances/WordPressInstanceInfo" asp-route-id="@instanceId">
                                Volver a comprobar
                            </a>
                            @if (!string.IsNullOrWhiteSpace(Model.Instance?.SiteAddress))
                            {
                                <a class="detail-link" href="https://@Model.Instance.SiteAddress" target="_blank">
                                    Abrir web
                                </a>
                            }
                        </div>
                    </div>
                </section>
            </div>

            <!-- Right Column -->
            <div class="flex flex-col gap-8">
                <!-- Primary Actions -->
                <div class="card">
                    <h2 class="card-title card-header">Acciones Principales</h2>
                    <div class="card-body action-buttons">
                        <form method="post" asp-page-handler="Start" asp-route-id="@instanceId">
                            <button type="submit"
                                    class="btn-action btn-start"
                                    disabled="@(Model.Instance?.DockerStatus is not "stopped")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">play_arrow</span>
                                <span>Iniciar</span>
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Stop" asp-route-id="@instanceId">
                            <button type="submit"
                                    class="btn-action btn-stop"
                                    disabled="@(Model.Instance?.DockerStatus is not "running")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">stop</span>
                                <span>Apagar</span>
                            </button>
                        </form>
                        <form method="post" asp-page-handler="Restart" asp-route-id="@instanceId">
                            <button type="submit"
                                    class="btn-action btn-restart"
                                    disabled="@(Model.Instance?.DockerStatus is not "running")">
                                <span class="material-symbols-outlined" style="font-size: 1.25rem;">refresh</span>
                                <span>Reiniciar</span>
                            </button>
                        </form>
                    </div>
                </div>
                <!-- Danger Zone -->
                <div class="danger-zone">
                    <h3 class="danger-title">Zona de Peligro</h3>
                    <p class="danger-description">Estas acciones son permanentes y no se pueden deshacer.</p>
                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('¿Estás seguro que quieres eliminar esta instancia? Esta acción no se puede deshacer.');"
                          class="danger-action">
                        <input type="hidden" name="id" value="@Model.Instance?.Id"/>
                        <div>
                            <p class="danger-action-text">Eliminar esta instancia</p>
                            <p class="danger-action-description">Una vez eliminada, desaparecerá para siempre.</p>
                            @if (Model.Instance?.DockerStatus != "stopped")
                            {
                                <p class="text-yellow-600 dark:text-yellow-400 text-sm mt-2">
                                    ⚠️ Debes apagar la instancia antes de eliminarla.
                                </p>
                            }
                        </div>
                        <button type="submit" class="btn-action btn-danger"
                                disabled="@(Model.Instance?.DockerStatus != "stopped")">
                            Eliminar Instancia
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
