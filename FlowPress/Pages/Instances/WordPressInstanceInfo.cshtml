@page "/instanceinfo/{id:guid}"
@model FlowPress.Pages.Instances.WordPressInstanceInfo

@{
    Layout = "_Layout";
    ViewData["Title"] = "Instance Info";
}

<main class="flex-1 p-6 lg:p-10">
    <div class="mx-auto max-w-7xl">
        <header class="mb-8">
            <div class="flex flex-wrap gap-2 mb-4">
                <a class="text-gray-500 dark:text-[#9dabb9] text-sm font-medium hover:text-primary dark:hover:text-primary"
                   href="/instances">Instances</a>
                <span class="text-gray-500 dark:text-[#9dabb9] text-sm font-medium">/</span>
                <span class="text-gray-800 dark:text-white text-sm font-medium">@Model.Instance?.SiteName</span>
            </div>
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <h1 class="text-gray-900 dark:text-white text-3xl lg:text-4xl font-black leading-tight tracking-[-0.033em]">
                        @Model.Instance?.SiteName
                    </h1>
                    @* <button class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white"> *@
                    @*     <span class="material-symbols-outlined text-lg">edit</span> *@
                    @* </button> *@
                </div>
                <div class="flex items-center gap-2 px-3 py-1 bg-green-100 dark:bg-green-900/40 rounded-full">
                    <span class="h-2 w-2 rounded-full bg-green-500"></span>
                    <p class="text-green-800 dark:text-green-400 text-sm font-medium">Running</p>
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column -->
            <div class="lg:col-span-1 flex flex-col gap-8">
                <div class="bg-white dark:bg-[#1C2834] rounded-xl shadow-sm">
                    <h2 class="text-gray-900 dark:text-white text-lg font-bold p-4 border-b border-gray-200 dark:border-white/10">
                        Instance Details</h2>
                    <div class="p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-y-4">
                        <div class="flex flex-col gap-1 pr-2">
                            <p class="text-gray-500 dark:text-[#9dabb9] text-sm">Site URL</p>
                            <a class="text-primary text-sm hover:underline"
                               href="https://@($"{Model.Instance?.SiteAddress}")">
                                @($"{Model.Instance?.SiteAddress}")
                            </a>

                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-gray-500 dark:text-[#9dabb9] text-sm">IP Address</p>
                            <p class="text-gray-800 dark:text-white text-sm">192.168.1.1</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-gray-500 dark:text-[#9dabb9] text-sm">WordPress Version</p>
                            <p class="text-gray-800 dark:text-white text-sm">6.1.1</p>
                        </div>
                        <div class="flex flex-col gap-1">
                            <p class="text-gray-500 dark:text-[#9dabb9] text-sm">PHP Version</p>
                            <p class="text-gray-800 dark:text-white text-sm">8.1</p>
                        </div>
                    </div>
                </div>

                <section
                    class="bg-white dark:bg-slate-900/70 border border-slate-200 dark:border-slate-800 rounded-lg shadow-sm">
                    <header class="p-4 border-b border-slate-200 dark:border-slate-800">
                        <h2 class="text-slate-900 dark:text-white text-lg font-bold">Monitoring</h2>
                    </header>
                    <div class="p-4 space-y-4">
                        <div class="flex items-center justify-between">
                            <span class="text-slate-500 dark:text-slate-400 text-sm">Current Status</span>
                            <span class="font-medium text-success text-sm">Up</span>
                        </div>
                        <div>
                            <div class="flex justify-between mb-1">
                                <span
                                    class="text-sm font-medium text-slate-500 dark:text-slate-400">Uptime (30 days)</span>
                                <span class="text-sm font-medium text-slate-800 dark:text-slate-200">99.98%</span>
                            </div>
                            <div class="w-full bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                                <div class="bg-success h-2 rounded-full" style="width: 99.98%"></div>
                            </div>
                        </div>
                        <a class="flex items-center gap-1.5 text-primary text-sm hover:underline" href="#">
                            <span>View Full Status Page</span>
                            <span class="material-symbols-outlined !text-sm">arrow_forward</span>
                        </a>
                    </div>
                </section>
            </div>

            <!-- Right Column -->
            <div class="lg:col-span-2 flex flex-col gap-8">
                <!-- ROLO Terminar de mirar y hacer toda la lógica -->
                <!-- Primary Actions -->
                <div class="bg-white dark:bg-[#1C2834] rounded-xl shadow-sm">
                    <h2 class="text-gray-900 dark:text-white text-lg font-bold p-4 border-b border-gray-200 dark:border-white/10">
                        Primary Actions
                    </h2>
                    <div class="p-4 flex flex-wrap gap-3">
                        <form method="post">
                            <button asp-page-handler="Start"
                                    class="flex items-center gap-2 h-10 px-4 rounded-lg bg-green-600/10 text-green-600 hover:bg-green-600/20">
                                <span class="material-symbols-outlined text-xl">play_arrow</span>
                                <span class="text-sm font-bold">Start</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Stop"
                                    class="flex items-center gap-2 h-10 px-4 rounded-lg bg-red-600/10 text-red-600 hover:bg-red-600/20">
                                <span class="material-symbols-outlined text-xl">stop</span>
                                <span class="text-sm font-bold">Stop</span>
                            </button>
                        </form>
                        <form method="post">
                            <button asp-page-handler="Restart"
                                    class="flex items-center gap-2 h-10 px-4 rounded-lg bg-yellow-500/10 text-yellow-600 hover:bg-yellow-500/20">
                                <span class="material-symbols-outlined text-xl">refresh</span>
                                <span class="text-sm font-bold">Restart</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Access Credentials -->
                <div class="bg-white dark:bg-[#1C2834] rounded-xl shadow-sm">
                    <h2 class="text-gray-900 dark:text-white text-lg font-bold p-4 border-b border-gray-200 dark:border-white/10">
                        Access Credentials</h2>
                    <div class="divide-y divide-gray-200 dark:divide-white/10">
                        <div class="p-4 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-2 items-center">
                            <div>
                                <p class="text-gray-500 dark:text-[#9dabb9] text-sm">SFTP/SSH Host</p>
                                <p class="text-gray-800 dark:text-white font-mono text-sm">sftp.myawesomesite.com</p>
                            </div>
                            <button
                                class="flex items-center gap-2 h-9 px-3 rounded-lg bg-primary/20 text-primary text-sm hover:bg-primary/30">
                                <span class="material-symbols-outlined text-base">content_copy</span>
                                <span>Copy</span>
                            </button>
                        </div>
                        <div class="p-4 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-2 items-center">
                            <div>
                                <p class="text-gray-500 dark:text-[#9dabb9] text-sm">Database Host</p>
                                <p class="text-gray-800 dark:text-white font-mono text-sm">db.myawesomesite.local</p>
                            </div>
                            <button
                                class="flex items-center gap-2 h-9 px-3 rounded-lg bg-primary/20 text-primary text-sm hover:bg-primary/30">
                                <span class="material-symbols-outlined text-base">content_copy</span>
                                <span>Copy</span>
                            </button>
                        </div>
                    </div>
                </div>
                
                <!--#region MEJORAS  -->
                <!-- WP-CLI -->
                @* <div class="bg-white dark:bg-[#1C2834] rounded-xl shadow-sm"> *@
                @*     <h2 class="text-gray-900 dark:text-white text-lg font-bold p-4 border-b border-gray-200 dark:border-white/10"> *@
                @*         WP-CLI Access</h2> *@
                @*     <div class="p-4"> *@
                @*         <div class="bg-black rounded-lg p-4 font-mono text-sm text-green-400 h-48 overflow-y-auto mb-4"> *@
                @*             <p>&gt; wp plugin list</p> *@
                @*             <p>+-------------------+----------+--------+---------+</p> *@
                @*             <p>| name | status | update | version |</p> *@
                @*             <p>+-------------------+----------+--------+---------+</p> *@
                @*             <p>| akismet | active | none | 5.0.2 |</p> *@
                @*             <p>| classic-editor | inactive | none | 1.6.2 |</p> *@
                @*             <p>| woocommerce | active | none | 7.3.0 |</p> *@
                @*             <p>+-------------------+----------+--------+---------+</p> *@
                @*         </div> *@
                @*         <div class="flex items-center gap-2"> *@
                @*             <span class="text-gray-400 dark:text-gray-500 font-mono text-sm">&gt;</span> *@
                @*             <input *@
                @*                 class="flex-1 bg-gray-100 dark:bg-[#101922] border-gray-300 dark:border-gray-700 rounded-md h-10 px-3 text-sm focus:ring-primary focus:border-primary" *@
                @*                 placeholder="Enter WP-CLI command..." type="text"/> *@
                @*             <button class="h-10 px-4 rounded-lg bg-primary text-white text-sm font-bold">Run</button> *@
                @*         </div> *@
                @*     </div> *@
                @* </div> *@
                <!--#endregion -->
                
                <!-- Danger Zone -->
                <div class="border border-red-500/30 dark:border-red-500/50 rounded-xl p-4">
                    <h3 class="text-red-700 dark:text-red-400 text-lg font-bold">Danger Zone</h3>
                    <p class="text-red-600/80 dark:text-red-400/80 text-sm mt-1">These actions are permanent and cannot be undone.</p>

                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('¿Estás seguro que quieres eliminar esta instancia? Esta acción no se puede deshacer.');"
                          class="mt-4 flex justify-between items-center">
                        <input type="hidden" name="id" value="@Model.Instance?.Id" />
                        <div>
                            <p class="text-gray-900 dark:text-white font-medium">Delete this instance</p>
                            <p class="text-gray-500 dark:text-gray-400 text-sm">Once deleted, it's gone forever.</p>
                        </div>
                        <button type="submit"
                                class="h-10 px-4 rounded-lg bg-red-600 text-white text-sm font-bold hover:bg-red-700">
                            Delete Instance
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>