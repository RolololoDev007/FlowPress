@page "/login"
@model FlowPress.Pages.Authentication.LoginPage
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<form method="post" asp-page-handler="Login">
    @Html.AntiForgeryToken()
    <div class="relative flex min-h-screen w-full flex-col items-center justify-center p-4">
        <main class="flex w-full max-w-md flex-col items-center justify-center">
            <div class="w-full rounded-xl bg-card-light dark:bg-card-dark p-8 shadow-sm">
                <div class="mb-8 text-center">
                    <p class="text-2xl font-bold tracking-tight text-text-light dark:text-text-dark">Log in to your account</p>
                    <p class="mt-2 text-sm text-subtle-light dark:text-subtle-dark">Enter your credentials to access your dashboard</p>
                </div>

                <div class="flex flex-col gap-6">
                    <label class="flex flex-col">
                        <p class="pb-2 text-sm font-medium">Email Address</p>
                        <div class="group flex w-full items-stretch rounded-lg">
                            <input asp-for="LoginModel.Email"
                                   class="form-input h-12 flex-1 resize-none overflow-hidden rounded-l-lg border border-border-light bg-background-light p-3 text-sm placeholder:text-subtle-light focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-border-dark dark:bg-gray-800 text-white dark:placeholder:text-subtle-dark"
                                   placeholder="Enter your email address"
                                   type="email"/>
                            <div class="flex items-center justify-center rounded-r-lg border border-l-0 border-border-light bg-background-light px-3 text-subtle-light group-focus-within:border-primary group-focus-within:text-primary dark:border-border-dark dark:bg-background-dark dark:text-subtle-dark">
                                <span class="material-symbols-outlined" style="font-size: 20px;">person</span>
                            </div>
                        </div>
                    </label>

                    <label class="flex flex-col">
                        <p class="pb-2 text-sm font-medium">Password</p>
                        <div class="group flex w-full items-stretch rounded-lg">
                            <input asp-for="LoginModel.Password"
                                   class="form-input h-12 flex-1 resize-none overflow-hidden rounded-l-lg border border-border-light bg-background-light p-3 text-sm placeholder:text-subtle-light focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-border-dark dark:bg-gray-800 text-white dark:placeholder:text-subtle-dark"
                                   placeholder="Enter your password"
                                   type="password"/>
                            <div class="flex items-center justify-center rounded-r-lg border border-l-0 border-border-light bg-background-light px-3 text-subtle-light group-focus-within:border-primary group-focus-within:text-primary dark:border-border-dark dark:bg-background-dark dark:text-subtle-dark">
                                <span class="material-symbols-outlined" style="font-size: 20px;">lock</span>
                            </div>
                        </div>
                    </label>

                    <button type="submit"
                            class="flex h-12 w-full items-center justify-center rounded-lg bg-blue-500 px-6 text-base font-semibold text-white transition-colors hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-100">
                        Log In
                    </button>

                </div>

                <p class="mt-4 text-sm text-subtle-light dark:text-subtle-dark">@ViewData["Message"]</p>
            </div>
        </main>
    </div>
</form>
