@page "/login"
@model FlowPress.Pages.Authentication.LoginPage
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth-forms.css" asp-append-version="true"/>
}

<form method="post" asp-page-handler="Login">
    @Html.AntiForgeryToken()
    <div class="form-container">
        <main class="form-card">
            <div class="form-header">
                <p class="form-title">Log in to your account</p>
                <p class="form-subtitle">Enter your credentials to access your dashboard</p>
            </div>

            <div class="flex flex-col gap-6">
                <label class="flex flex-col">
                    <p class="form-label">Email Address</p>
                    <div class="input-group">
                        <input asp-for="LoginModel.Email" class="form-input" placeholder="Enter your email address"
                               type="email"/>
                        <div class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">person</span>
                        </div>
                    </div>
                </label>

                <label class="flex flex-col">
                    <p class="form-label">Password</p>
                    <div class="input-group">
                        <input asp-for="LoginModel.Password" class="form-input" placeholder="Enter your password"
                               type="password"/>
                        <div class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">lock</span>
                        </div>
                    </div>
                </label>

                <button type="submit" class="btn-primary">Log In</button>
            </div>

            <p class="mt-4 form-subtitle">@ViewData["Message"]</p>
        </main>
    </div>
</form>