@page "/register"
@model RegisterPage

@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

@section Scripts
{
    <script src="~/js/register.js" asp-append-version="true"></script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Authentication/auth-forms.css" asp-append-version="true"/>
}

<form method="post" asp-antiforgery="true">
    <div class="form-container">
        <main class="form-card">
            <div class="form-header">
                <p class="form-title">Create Your Account</p>
                <p class="form-subtitle">Manage all your WordPress sites from one place.</p>
            </div>
            <div class="flex flex-col gap-6">
                <!-- Username -->
                <label class="flex flex-col">
                    <p class="form-label">Username</p>
                    <div class="input-group">
                        <input asp-for="RegisterModel.Username" class="form-input" placeholder="Enter your username"
                               type="text"/>
                        <div class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">person</span>
                        </div>
                    </div>
                    <span asp-validation-for="RegisterModel.Username" class="validation-error"></span>
                </label>
                <!-- Email -->
                <label class="flex flex-col">
                    <p class="form-label">Email Address</p>
                    <div class="input-group">
                        <input asp-for="RegisterModel.Email" class="form-input" placeholder="Enter your email address"
                               type="email"/>
                        <div class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">email</span>
                        </div>
                    </div>
                    <span asp-validation-for="RegisterModel.Email" class="validation-error"></span>
                </label>
                <!-- Password -->
                <label class="flex flex-col">
                    <p class="form-label">Password</p>
                    <div class="input-group">
                        <input asp-for="RegisterModel.Password" class="form-input" placeholder="Create a password"
                               type="password"/>
                        <button type="button" id="togglePassword" class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">visibility</span>
                        </button>
                    </div>
                </label>
                <!-- Confirm Password -->
                <label class="flex flex-col">
                    <p class="form-label">Confirm Password</p>
                    <div class="input-group">
                        <input asp-for="RegisterModel.ConfirmPassword" class="form-input"
                               placeholder="Confirm your password" type="password"/>
                        <button type="button" id="toggleConfirmPassword" class="input-icon">
                            <span class="material-symbols-outlined" style="font-size: 20px;">visibility</span>
                        </button>
                    </div>
                    <span asp-validation-for="RegisterModel.ConfirmPassword" class="validation-error"></span>
                </label>
                <span asp-validation-for="RegisterModel.Password" class="validation-error"></span>
                <div class="password-requirements">
                    <p class="validation-error">Password must be at least 6 characters long.</p>
                    <div class="password-strength">
                        <div class="password-strength-bg">
                            <div id="passwordStrengthBar" class="password-strength-bar"
                                 style="width: 0%;"></div>
                        </div>
                        <span id="passwordStrengthText" class="password-strength-text"> </span>
                    </div>
                </div>
                <!-- Register Button -->
                <button type="submit" class="btn-primary" disabled="@Model.IsRegistering">
                    @if (Model.IsRegistering)
                    {
                        <text>Registering...</text>
                    }
                    else
                    {
                        <text>Register</text>
                    }
                </button>
            </div>
            <!-- Sign In Link -->
            <p class="form-subtitle text-center" style="margin-top: 1rem;">
                Already have an account?
                <a class="text-link" asp-page="/Login">Sign In</a>
            </p>
            <!-- General messages -->
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <p class="form-subtitle text-center" style="margin-top: 1rem;">@Model.Message</p>
            }
        </main>
    </div>
</form>
